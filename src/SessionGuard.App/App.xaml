<Application x:Class="SessionGuard.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F3F5F7" />
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#D7DCE1" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#0F172A" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#475569" />
        <SolidColorBrush x:Key="PrimaryButtonBrush" Color="#0F62FE" />
        <SolidColorBrush x:Key="PrimaryButtonHoverBrush" Color="#0849BF" />
        <SolidColorBrush x:Key="SecondaryButtonBrush" Color="#E2E8F0" />
        <SolidColorBrush x:Key="SecondaryButtonHoverBrush" Color="#CBD5E1" />
        <SolidColorBrush x:Key="QuietButtonBrush" Color="#EEF2F6" />
        <SolidColorBrush x:Key="QuietButtonHoverBrush" Color="#E2E8F0" />

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource PrimaryButtonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryButtonBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryButtonHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryButtonHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{StaticResource SecondaryButtonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SecondaryButtonBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource SecondaryButtonHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource SecondaryButtonHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="QuietActionButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,0,0" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="Background" Value="{StaticResource QuietButtonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource QuietButtonBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource QuietButtonHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource QuietButtonHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>
