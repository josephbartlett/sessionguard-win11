<Window x:Class="SessionGuard.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SessionGuard"
        Width="1260"
        Height="860"
        MinWidth="1080"
        MinHeight="720"
        Background="{StaticResource WindowBackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock FontSize="30"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               Text="SessionGuard" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Text="Reduce surprise Windows restart disruption without disabling Windows Update."
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource PrimaryActionButtonStyle}"
                            Command="{Binding ScanNowCommand}"
                            Content="Scan now" />
                    <Button Style="{StaticResource SecondaryActionButtonStyle}"
                            Command="{Binding OpenWindowsUpdateSettingsCommand}"
                            Content="Windows Update options" />
                </StackPanel>
            </DockPanel>

            <Grid Grid.Row="1" Margin="0,22,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="380" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="Current status" />
                            <Border Margin="0,12,0,0"
                                    Padding="14,8"
                                    HorizontalAlignment="Left"
                                    Background="{Binding StatusBrush}"
                                    CornerRadius="999">
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           Text="{Binding CurrentStatusText}" />
                            </Border>

                            <TextBlock Margin="0,14,0,0"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       Text="{Binding StatusSummary}"
                                       TextWrapping="Wrap" />

                            <UniformGrid Margin="0,18,0,0" Columns="2">
                                <Border Margin="0,0,10,10"
                                        Padding="12"
                                        Background="#F8FAFC"
                                        CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource SecondaryTextBrush}" Text="Restart risk" />
                                        <TextBlock Margin="0,8,0,0"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding RiskBrush}"
                                                   Text="{Binding RestartRiskText}" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        Background="#F8FAFC"
                                        CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource SecondaryTextBrush}" Text="Protection mode" />
                                        <TextBlock Margin="0,8,0,0"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   Text="{Binding ProtectionModeText}" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,0,10,10"
                                        Padding="12"
                                        Background="#F8FAFC"
                                        CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource SecondaryTextBrush}" Text="Pending restart" />
                                        <TextBlock Margin="0,8,0,0"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   Text="{Binding PendingRestartText}" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        Background="#F8FAFC"
                                        CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource SecondaryTextBrush}" Text="Admin access" />
                                        <TextBlock Margin="0,8,0,0"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   Text="{Binding AdminAccessText}" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <CheckBox Margin="0,8,0,0"
                                      Content="Guard mode enabled"
                                      FontWeight="SemiBold"
                                      IsChecked="{Binding GuardModeEnabled}" />

                            <TextBlock Margin="0,12,0,0"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="{Binding LastScanText}" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="{Binding ProtectedProcessSummary}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,12,0,0"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       Text="{Binding LastActionMessage}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,16,0,0" Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="Actions" />

                            <WrapPanel Margin="0,14,0,0">
                                <Button Style="{StaticResource PrimaryActionButtonStyle}"
                                        Command="{Binding ApplyMitigationsCommand}"
                                        Content="Apply recommended mitigation" />
                                <Button Style="{StaticResource SecondaryActionButtonStyle}"
                                        Command="{Binding ResetMitigationsCommand}"
                                        Content="Reset managed settings" />
                            </WrapPanel>

                            <WrapPanel Margin="0,12,0,0">
                                <Button Style="{StaticResource SecondaryActionButtonStyle}"
                                        Command="{Binding OpenConfigCommand}"
                                        Content="Open config" />
                                <Button Style="{StaticResource SecondaryActionButtonStyle}"
                                        Command="{Binding OpenLogsCommand}"
                                        Content="Open logs" />
                            </WrapPanel>

                            <TextBlock Margin="0,16,0,0"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="Recommendations" />

                            <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding Recommendations}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,0,8"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   Text="{Binding}"
                                                   TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Margin="0,12,0,0"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="{Binding ConfigurationDirectoryText}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="{Binding LogDirectoryText}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="Protected process matches" />
                            <DataGrid Margin="0,14,0,0"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      IsReadOnly="True"
                                      ItemsSource="{Binding ProtectedProcesses}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Width="*" Binding="{Binding DisplayName}" Header="Process" />
                                    <DataGridTextColumn Width="140" Binding="{Binding InstanceCount}" Header="Instances" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,16,0,0" Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="Restart indicators" />
                            <DataGrid Margin="0,14,0,0"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      IsReadOnly="True"
                                      ItemsSource="{Binding RestartIndicators}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Width="220" Binding="{Binding Source}" Header="Signal" />
                                    <DataGridCheckBoxColumn Width="90" Binding="{Binding IsActive}" Header="Active" />
                                    <DataGridTextColumn Width="100" Binding="{Binding Confidence}" Header="Confidence" />
                                    <DataGridCheckBoxColumn Width="120" Binding="{Binding LimitedVisibility}" Header="Limited view" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <ItemsControl Margin="0,12,0,0"
                                          Visibility="{Binding ShowDetailedSignals, Converter={StaticResource BooleanToVisibilityConverter}}"
                                          ItemsSource="{Binding RestartIndicators}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,0,8"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   Text="{Binding Summary}"
                                                   TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,16,0,0" Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="Managed mitigation state" />
                            <DataGrid Margin="0,14,0,0"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      IsReadOnly="True"
                                      ItemsSource="{Binding ManagedMitigations}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Width="220" Binding="{Binding DisplayName}" Header="Setting" />
                                    <DataGridCheckBoxColumn Width="80" Binding="{Binding IsApplied}" Header="Applied" />
                                    <DataGridTextColumn Width="130" Binding="{Binding CurrentValue}" Header="Current" />
                                    <DataGridTextColumn Width="130" Binding="{Binding RecommendedValue}" Header="Recommended" />
                                    <DataGridCheckBoxColumn Width="120" Binding="{Binding RequiresElevation}" Header="Needs admin" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
